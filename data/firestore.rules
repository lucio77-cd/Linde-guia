// firestore.rules
// Linde Guia — Treze Tílias
//
// Modelo: leitura pública dos dados turísticos (pois, eventos) — é um guia
// pra visitantes, não precisa de login pra ver conteúdo.
// Escrita restrita a administradores (Secretaria de Turismo / ASTURTILIAS),
// que usam o painel admin/admin.html.
// Dados de usuário (perfil, rotas salvas) só o próprio dono acessa.
//
// IMPORTANTE: este arquivo precisa de uma coleção "usuarios_admin" no
// Firestore, com um documento por admin autorizado (doc ID = uid do Firebase
// Auth daquele admin). Sem isso, ninguém consegue escrever em "pois"/"eventos".
// Crie esse documento manualmente no Console depois que o primeiro admin
// fizer login pela primeira vez.
//
// RESOLVIDO (era uma pendencia conhecida): admin-auth.js agora loga de
// verdade no Firebase Auth (signInWithEmailAndPassword, uma unica conta
// e-mail/senha compartilhada - ver comentario de setup em admin-auth.js).
// Antes, o painel so autenticava com senha local em sessionStorage, entao
// toda chamada de admin-locais.js/admin-estatisticas.js caia em
// "permission-denied" contra a funcao ehAdmin() abaixo, mesmo com a senha
// certa. Passo que falta pra funcionar de ponta a ponta: criar a conta no
// Firebase Console (Authentication) e o documento correspondente em
// usuarios_admin com o UID dessa conta - ver checklist em admin-auth.js.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // FUNÇÕES AUXILIARES
    // ============================================================

    function estaLogado() {
      return request.auth != null;
    }

    // Verifica se o uid logado tem um documento em "usuarios_admin".
    // Só usar quando estaLogado() já for verdade (senão request.auth.uid é nulo).
    function ehAdmin() {
      return estaLogado() &&
        exists(/databases/$(database)/documents/usuarios_admin/$(request.auth.uid));
    }

    // O usuário só pode tocar no PRÓPRIO documento (users/{uid})
    function ehDonoDoDocumento(userId) {
      return estaLogado() && request.auth.uid == userId;
    }

    // ============================================================
    // POIS — leitura pública, escrita só admin, com validação de campo
    // ============================================================
    match /pois/{poiId} {
      allow get, list: if true;

      allow create: if ehAdmin() && poiTemCamposValidos();
      allow update: if ehAdmin() && poiTemCamposValidos();
      allow delete: if ehAdmin();

      // Validação mínima: nunca aceitar POI sem nome, com preço negativo,
      // ou com statusOperacional fora do conjunto permitido.
      //
      // CORRIGIDO: a validação antes checava os campos em snake_case
      // (preco_estimado / status_operacional), mas nenhum código do
      // projeto escreve nesse formato — admin-locais.js e o seed usam
      // camelCase (precoEstimado / statusOperacional). Isso fazia a
      // validação nunca disparar de verdade (o campo checado nunca
      // existia com aquele nome, então a condição sempre passava).
      function poiTemCamposValidos() {
        let dados = request.resource.data;
        return dados.nome is string && dados.nome.size() > 0
          && dados.categoria is string
          && (!('precoEstimado' in dados) || dados.precoEstimado is number && dados.precoEstimado >= 0)
          && (!('statusOperacional' in dados) ||
              dados.statusOperacional in ['ativo', 'sazonal', 'em_reforma', 'fechado_temporariamente']);
      }
    }

    // ============================================================
    // EVENTOS — mesmo padrão dos POIs
    // ============================================================
    match /eventos/{eventoId} {
      allow get, list: if true;

      allow create, update: if ehAdmin() && eventoTemCamposValidos();
      allow delete: if ehAdmin();

      // ATENÇÃO: ainda não existe um admin-eventos.js confirmado no projeto.
      // Quando ele for criado, usar os MESMOS nomes de campo checados aqui
      // (data_inicio / data_fim, snake_case) — senão essa validação cai no
      // mesmo problema que a de "pois" tinha (checar um nome de campo que
      // o app nunca escreve, e por isso nunca validar nada de verdade).
      function eventoTemCamposValidos() {
        let dados = request.resource.data;
        return dados.nome is string && dados.nome.size() > 0
          && (!('data_inicio' in dados) || dados.data_inicio is timestamp)
          && (!('data_fim' in dados) || dados.data_fim is timestamp);
      }
    }

    // ============================================================
    // PATROCINADORES — banner de anúncio pago, mostrado em todas as
    // páginas voltadas pro turista. Leitura pública (senão o banner nunca
    // carregaria pra ninguém), escrita só pelo admin master.
    // ============================================================
    match /patrocinadores/{patrocinadorId} {
      allow get, list: if true;

      allow create, update: if ehAdmin() && patrocinadorTemCamposValidos();
      allow delete: if ehAdmin();

      // Nomes em camelCase — mesmo padrão que admin-locais.js já usa pra
      // "pois", pra não repetir o bug antigo de checar snake_case contra
      // dado que o app sempre escreve em camelCase.
      function patrocinadorTemCamposValidos() {
        let dados = request.resource.data;
        return dados.nome is string && dados.nome.size() > 0
          && dados.imagemUrl is string
          && dados.linkDestino is string
          && dados.ativo is bool;
      }
    }

    // ============================================================
    // USUARIOS_ADMIN — quem é admin. Só admin LÊ; ninguém escreve via app.
    // ============================================================
    // Escrita nesta coleção é feita manualmente pelo Console do Firebase
    // (ou Admin SDK em um script de setup), nunca pelo client. Por isso
    // não existe "allow write" aqui — fica negado por padrão.
    match /usuarios_admin/{adminId} {
      allow get: if ehAdmin();
      allow list: if false; // impede listar todos os admins por enumeração
    }

    // ============================================================
    // USUARIOS — perfil, favoritos. Só o próprio dono acessa.
    // ============================================================
    match /usuarios/{userId} {
      allow read, write: if ehDonoDoDocumento(userId);
    }

    // ============================================================
    // ROTAS_GERADAS — histórico de rotas (analytics interno)
    // ============================================================
    // Usuário logado pode salvar/ler a própria rota. Admin pode ler tudo
    // (pra entender o que mais é pedido), mas não escreve aqui diretamente.
    //
    // ATENÇÃO: nenhum código do app atual grava nesta coleção — o fluxo
    // real (formulario-roteiro.js / modo-em-rota.js) usa "rotas_criadas"
    // e "checkins" (ver regras abaixo). Mantida aqui caso "Minhas Rotas"
    // (perfil de usuário logado) seja implementado no futuro; se não for
    // usada, pode ser removida.
    match /rotas_geradas/{rotaId} {
      allow create: if estaLogado() && request.resource.data.userId == request.auth.uid;
      allow get: if estaLogado() &&
        (resource.data.userId == request.auth.uid || ehAdmin());
      allow list: if ehAdmin();
      allow update, delete: if false; // rota gerada é histórico, não se edita
    }

    // ============================================================
    // ROTAS_CRIADAS — eventos de analytics (criação/finalização de roteiro)
    // ============================================================
    // Gravada por registro-data.js a partir do fluxo público do turista
    // (formulario-roteiro.js no "Criar roteiro", modo-em-rota.js ao
    // finalizar) — SEM login, então a escrita precisa ser pública, como
    // qualquer analytics anônimo. Só o painel admin lê os dados
    // agregados (admin-estatisticas.js). Histórico: nunca se edita ou
    // apaga por aqui.
    //
    // create exige tipoEvento válido para impedir que a coleção pública
    // seja usada para gravar lixo arbitrário sem relação com o app.
    match /rotas_criadas/{registroId} {
      allow create: if registroRotaTemCamposValidos();
      allow get, list: if ehAdmin();
      allow update, delete: if false;

      function registroRotaTemCamposValidos() {
        let dados = request.resource.data;
        return dados.criadoEm is timestamp
          && (!('tipoEvento' in dados) || dados.tipoEvento in ['criacao', 'finalizacao']);
      }
    }

    // ============================================================
    // CHECKINS — eventos de analytics (check-in manual "Cheguei")
    // ============================================================
    // Mesmo padrão de rotas_criadas: gravado sem login pelo turista
    // durante o passeio (modo-em-rota.js), lido só pelo admin.
    match /checkins/{checkinId} {
      allow create: if checkinTemCamposValidos();
      allow get, list: if ehAdmin();
      allow update, delete: if false;

      // poiNome é tratado como opcional pelo próprio painel
      // (admin-estatisticas.js cai para "Desconhecido" se ausente), então
      // a regra não exige o campo — só valida o tipo quando ele existe.
      function checkinTemCamposValidos() {
        let dados = request.resource.data;
        return dados.checkinEm is timestamp
          && (!('poiNome' in dados) || dados.poiNome is string);
      }
    }

    // ============================================================
    // PADRÃO: qualquer coisa fora do mapeado acima é NEGADA
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
